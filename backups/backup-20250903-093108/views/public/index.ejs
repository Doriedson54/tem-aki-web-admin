<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tem Aki no Bairro - Descubra negócios locais</title>
    <meta name="description" content="Cadastre e descubra negócios locais no seu bairro. Conecte-se com comércios, serviços e estabelecimentos próximos a você.">
    <meta name="keywords" content="negócios locais, comércio local, bairro, estabelecimentos, serviços">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #2c5aa0;
            --secondary-color: #f8f9fa;
            --accent-color: #28a745;
            --text-dark: #333;
            --text-light: #666;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: var(--text-dark);
        }
        
        .hero-section {
            background: linear-gradient(135deg, var(--primary-color) 0%, #1e3a5f 100%);
            color: white;
            padding: 100px 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        
        .hero-content h1 {
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
        }
        
        .hero-content p {
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.9;
        }
        
        .download-buttons {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        
        .btn-download {
            padding: 15px 30px;
            font-size: 1.1rem;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }
        
        .btn-playstore {
            background: var(--accent-color);
            color: white;
            border: 2px solid var(--accent-color);
        }
        
        .btn-playstore:hover {
            background: transparent;
            color: var(--accent-color);
        }
        
        .btn-apk {
            background: transparent;
            color: white;
            border: 2px solid white;
        }
        
        .btn-apk:hover {
            background: white;
            color: var(--primary-color);
        }
        
        .features-section {
            padding: 80px 0;
            background: var(--secondary-color);
        }
        
        .feature-card {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            text-align: center;
            height: 100%;
            transition: transform 0.3s ease;
        }
        
        .feature-card:hover {
            transform: translateY(-5px);
        }
        
        .feature-icon {
            font-size: 3rem;
            color: var(--primary-color);
            margin-bottom: 1rem;
        }
        
        .web-directory-section {
            padding: 80px 0;
        }
        
        .business-card {
            background: white;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: transform 0.3s ease;
        }
        
        .business-card:hover {
            transform: translateY(-3px);
        }
        
        .footer {
            background: var(--text-dark);
            color: white;
            padding: 40px 0;
            text-align: center;
        }
        
        @media (max-width: 768px) {
            .hero-content h1 {
                font-size: 2.5rem;
            }
            
            .download-buttons {
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <div class="hero-content">
                        <h1>Tem Aki no Bairro</h1>
                        <p>Cadastre e descubra negócios locais no seu bairro. Conecte-se com comércios, serviços e estabelecimentos próximos a você.</p>
                        
                        <div class="download-buttons">
                            <a href="#" class="btn-download btn-playstore">
                                <i class="fab fa-google-play"></i>
                                Baixar na Google Play
                            </a>
                            <a href="#" class="btn-download btn-apk">
                                <i class="fas fa-download"></i>
                                Download APK
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="text-center">
                        <img src="/tem_aki_logo.png" alt="Tem Aki no Bairro" class="img-fluid" style="max-width: 300px;">
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Features Section -->
    <section class="features-section">
        <div class="container">
            <div class="row text-center mb-5">
                <div class="col-12">
                    <h2 data-aos="fade-up">Por que usar o Tem Aki?</h2>
                    <p class="lead" data-aos="fade-up" data-aos-delay="100">Descubra as vantagens de ter todos os negócios do seu bairro na palma da sua mão</p>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <h4>Localização Precisa</h4>
                        <p>Encontre negócios próximos a você com localização em tempo real e direções precisas.</p>
                    </div>
                </div>
                
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-store"></i>
                        </div>
                        <h4>Variedade de Negócios</h4>
                        <p>Comércios, serviços, restaurantes, farmácias e muito mais, tudo em um só lugar.</p>
                    </div>
                </div>
                
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-heart"></i>
                        </div>
                        <h4>Apoie o Local</h4>
                        <p>Fortaleça a economia do seu bairro apoiando negócios locais e empreendedores.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Web Directory Section -->
    <section class="web-directory-section">
        <div class="container">
            <div class="row text-center mb-5">
                <div class="col-12">
                    <h2 data-aos="fade-up">Explore Negócios Online</h2>
                    <p class="lead" data-aos="fade-up" data-aos-delay="100">Navegue pelos estabelecimentos diretamente pelo seu navegador</p>
                </div>
            </div>
            
            <div class="row">
                <div class="col-12">
                    <div class="text-center mb-4">
                        <a href="/directory" class="btn btn-primary btn-lg">
                            <i class="fas fa-search"></i>
                            Ver Diretório Completo
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Preview de alguns negócios -->
            <div id="businessPreview" class="row">
                <!-- Negócios serão carregados aqui via JavaScript -->
            </div>
        </div>
    </section>
    
    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <p>&copy; 2024 Tem Aki no Bairro. Todos os direitos reservados.</p>
                    <p>Conectando você aos negócios do seu bairro.</p>
                </div>
            </div>
        </div>
    </footer>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    
    <script>
        // Inicializar AOS quando disponível
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof AOS !== 'undefined') {
                AOS.init({
                    duration: 1000,
                    once: true
                });
            }
        });
        
        // Carregar preview de negócios
        async function loadBusinessPreview() {
            try {
                const response = await fetch('/api/businesses/preview');
                const businesses = await response.json();
                
                const container = document.getElementById('businessPreview');
                container.innerHTML = '';
                
                businesses.slice(0, 6).forEach(business => {
                    const businessCard = `
                        <div class="col-md-4 mb-4">
                            <div class="business-card">
                                <h5>${business.name}</h5>
                                <p class="text-muted">${business.category}</p>
                                <p>${business.description ? business.description.substring(0, 100) + '...' : 'Sem descrição disponível'}</p>
                                <small class="text-muted">
                                    <i class="fas fa-map-marker-alt"></i>
                                    ${business.address || 'Endereço não informado'}
                                </small>
                            </div>
                        </div>
                    `;
                    container.innerHTML += businessCard;
                });
            } catch (error) {
                console.log('Erro ao carregar negócios:', error);
                document.getElementById('businessPreview').innerHTML = `
                    <div class="col-12 text-center">
                        <p class="text-muted">Carregando negócios...</p>
                    </div>
                `;
            }
        }
        
        // Carregar negócios quando a página carregar
        document.addEventListener('DOMContentLoaded', loadBusinessPreview);
    </script>
</body>
</html>