<% layout('layout') %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <h1 class="h2">Relatório de Moderação</h1>
  <div class="btn-toolbar mb-2 mb-md-0">
    <div class="btn-group me-2">
      <a href="/businesses" class="btn btn-sm btn-outline-primary">
        <i class="fas fa-building"></i> Voltar para Negócios
      </a>
      <a href="/reports" class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Voltar aos Relatórios
      </a>
    </div>
  </div>
</div>

<!-- Filtros -->
<div class="card mb-4">
  <div class="card-header">
    <h5 class="card-title mb-0">
      <i class="fas fa-filter"></i> Filtros
    </h5>
  </div>
  <div class="card-body">
    <form method="GET" action="/reports/moderation">
      <div class="row">
        <div class="col-md-3">
          <div class="mb-3">
            <label for="user_id" class="form-label">Moderador</label>
            <select class="form-select" id="user_id" name="user_id">
              <option value="">Todos os moderadores</option>
              <% users.forEach(user => { %>
                <option value="<%= user.id %>" <%= filters.user_id == user.id ? 'selected' : '' %>>
                  <%= user.username %>
                </option>
              <% }); %>
            </select>
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <label for="action" class="form-label">Ação</label>
            <select class="form-select" id="action" name="action">
              <option value="">Todas as ações</option>
              <option value="approve" <%= filters.action === 'approve' ? 'selected' : '' %>>Aprovação</option>
              <option value="reject" <%= filters.action === 'reject' ? 'selected' : '' %>>Rejeição</option>
              <option value="feature" <%= filters.action === 'feature' ? 'selected' : '' %>>Destacar</option>
              <option value="unfeature" <%= filters.action === 'unfeature' ? 'selected' : '' %>>Remover Destaque</option>
            </select>
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <label for="date_from" class="form-label">Data Inicial</label>
            <input type="date" class="form-control" id="date_from" name="date_from" value="<%= filters.date_from || '' %>">
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <label for="date_to" class="form-label">Data Final</label>
            <input type="date" class="form-control" id="date_to" name="date_to" value="<%= filters.date_to || '' %>">
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-search"></i> Filtrar
          </button>
          <a href="/reports/moderation" class="btn btn-secondary">
            <i class="fas fa-times"></i> Limpar Filtros
          </a>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Resultados -->
<div class="card">
  <div class="card-header">
    <h5 class="card-title mb-0">
      <i class="fas fa-list"></i> Histórico de Moderação
      <span class="badge bg-secondary ms-2"><%= moderations.length %> registros</span>
    </h5>
  </div>
  <div class="card-body">
    <% if (moderations && moderations.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead class="table-dark">
            <tr>
              <th>Data/Hora</th>
              <th>Negócio</th>
              <th>Categoria</th>
              <th>Ação</th>
              <th>Status Anterior</th>
              <th>Novo Status</th>
              <th>Moderador</th>
              <th>Motivo/Observações</th>
            </tr>
          </thead>
          <tbody>
            <% moderations.forEach(moderation => { %>
            <tr>
              <td>
                <small><%= new Date(moderation.created_at).toLocaleString('pt-BR') %></small>
              </td>
              <td>
                <% if (moderation.business_name) { %>
                  <a href="/business/<%= moderation.business_id %>" class="text-decoration-none fw-bold">
                    <%= moderation.business_name %>
                  </a>
                <% } else { %>
                  <span class="text-muted">Negócio removido</span>
                <% } %>
              </td>
              <td>
                <% if (moderation.category_name) { %>
                  <span class="badge bg-light text-dark"><%= moderation.category_name %></span>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
              <td>
                <% if (moderation.action === 'approve') { %>
                  <span class="badge bg-success">
                    <i class="fas fa-check"></i> Aprovado
                  </span>
                <% } else if (moderation.action === 'reject') { %>
                  <span class="badge bg-danger">
                    <i class="fas fa-times"></i> Rejeitado
                  </span>
                <% } else if (moderation.action === 'feature') { %>
                  <span class="badge bg-warning">
                    <i class="fas fa-star"></i> Destacado
                  </span>
                <% } else if (moderation.action === 'unfeature') { %>
                  <span class="badge bg-secondary">
                    <i class="fas fa-star-o"></i> Destaque Removido
                  </span>
                <% } else { %>
                  <span class="badge bg-info"><%= moderation.action %></span>
                <% } %>
              </td>
              <td>
                <% if (moderation.previous_status) { %>
                  <span class="badge bg-secondary"><%= moderation.previous_status %></span>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
              <td>
                <% if (moderation.new_status) { %>
                  <span class="badge bg-primary"><%= moderation.new_status %></span>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
              <td>
                <span class="fw-bold"><%= moderation.username || 'Sistema' %></span>
              </td>
              <td>
                <% if (moderation.reason || moderation.notes) { %>
                  <span class="text-break"><%= moderation.reason || moderation.notes %></span>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      
      <% if (moderations.length === 100) { %>
        <div class="alert alert-info mt-3">
          <i class="fas fa-info-circle"></i>
          Mostrando os primeiros 100 registros. Use os filtros para refinar sua busca.
        </div>
      <% } %>
    <% } else { %>
      <div class="text-center py-5">
        <i class="fas fa-search fa-3x text-gray-300 mb-3"></i>
        <h5 class="text-muted">Nenhum registro encontrado</h5>
        <p class="text-muted">Tente ajustar os filtros ou verificar se há atividades de moderação registradas.</p>
      </div>
    <% } %>
  </div>
</div>

<style>
  .text-gray-300 {
    color: #dddfeb !important;
  }
  .table th {
    border-top: none;
    font-weight: 600;
    font-size: 0.875rem;
  }
  .table td {
    vertical-align: middle;
    font-size: 0.875rem;
  }
  .badge {
    font-size: 0.75rem;
  }
</style>