// Quick Search
document.getElementById('quickSearchForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const query = document.getElementById('quickSearch').value;
    
    if (query.length < 2) {
        document.getElementById('searchResults').innerHTML = '';
        return;
    }
    
    fetch(`/dashboard/search?q=${encodeURIComponent(query)}`)
        .then(response => response.json())
        .then(data => {
            const resultsDiv = document.getElementById('searchResults');
            
            if (data.length === 0) {
                resultsDiv.innerHTML = '<small class="text-muted">Nenhum resultado encontrado.</small>';
                return;
            }
            
            let html = '<div class="list-group list-group-flush">';
            data.forEach(item => {
                html += `
                    <a href="/${item.type}s/${item.id}" class="list-group-item list-group-item-action py-2">
                        <div class="d-flex w-100 justify-content-between">
                            <small><strong>${item.name}</strong></small>
                            <small class="text-muted">${item.type === 'business' ? 'Negócio' : 'Categoria'}</small>
                        </div>
                    </a>
                `;
            });
            html += '</div>';
            
            resultsDiv.innerHTML = html;
        })
        .catch(error => {
            console.error('Error:', error);
        });
});

