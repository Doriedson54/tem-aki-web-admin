// Aprovação rápida de negócio
function approveBusinessQuick(businessId) {
    if (confirm('Tem certeza que deseja aprovar este negócio?')) {
        fetch(`/business/${businessId}/approve`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Atualizar a página para refletir as mudanças
                location.reload();
            } else {
                alert('Erro ao aprovar negócio: ' + (data.message || 'Erro desconhecido'));
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Erro ao aprovar negócio.');
        });
    }
}

// Função para formatar números
function formatNumber(num) {
    return new Intl.NumberFormat('pt-BR').format(num);
}

// Função para animar contadores
function animateCounters() {
    const counters = document.querySelectorAll('.stats-card h3');
    counters.forEach(counter => {
        const target = parseInt(counter.innerText);
        const increment = target / 50;
        let current = 0;
        
        const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
                counter.innerText = target;
                clearInterval(timer);
            } else {
                counter.innerText = Math.floor(current);
            }
        }, 30);
    });
}

// Adicionar efeitos de hover nos botões de ação
function addButtonEffects() {
    const actionButtons = document.querySelectorAll('.btn');
    actionButtons.forEach(button => {
        button.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-2px)';
            this.style.boxShadow = '0 5px 15px rgba(0,0,0,0.2)';
        });
        
        button.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0)';
            this.style.boxShadow = '';
        });
    });
}

// Adicionar animação de carregamento aos links de paginação
function addLoadingAnimation() {
    const links = document.querySelectorAll('a[href]');
    links.forEach(link => {
        link.addEventListener('click', function(e) {
            if (!this.href.includes('#') && !this.href.includes('javascript:')) {
                this.innerHTML += ' <i class="fas fa-spinner fa-spin"></i>';
            }
        });
    });
}

// Função para rolagem suave
function enableSmoothScroll() {
    document.documentElement.style.scrollBehavior = 'smooth';
}

// Adicionar efeito de pulso ao primeiro cartão de estatísticas
function addPulseEffect() {
    const firstCard = document.querySelector('.dashboard-stat-card');
    if (firstCard) {
        setTimeout(() => {
            firstCard.style.animation = 'pulse 2s infinite';
        }, 3000);
    }
}

// Função para aguardar o carregamento das bibliotecas
function waitForLibraries() {
    return new Promise((resolve) => {
        const checkLibraries = () => {
            if (typeof Chart !== 'undefined' && typeof AOS !== 'undefined') {
                resolve();
            } else {
                setTimeout(checkLibraries, 100);
            }
        };
        checkLibraries();
    });
}

// Initialize charts when page loads
document.addEventListener('DOMContentLoaded', async function() {
    // Aguardar o carregamento das bibliotecas
    await waitForLibraries();
    
    // Inicializar AOS (Animate On Scroll)
    AOS.init({
        duration: 800,
        easing: 'ease-in-out',
        once: true,
        offset: 100
    });
    
    // Inicializar contadores animados
    setTimeout(initCounters, 500);
    
    // Inicializar gráficos
    initCharts();
    
    // Adicionar efeitos interativos
    addButtonEffects();
    addLoadingAnimation();
    enableSmoothScroll();
    addPulseEffect();
    
    // Adicionar animação de entrada para os cartões
    const cards = document.querySelectorAll('.card');
    cards.forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        
        setTimeout(() => {
            card.style.transition = 'all 0.6s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
        }, index * 100);
    });
});

